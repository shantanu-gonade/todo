<?xml version="1.0" encoding="utf-8"?>
<resources>
    <!--
        Night-mode override. Dark background avoids white flash before Compose draws.
        Inherits from the day theme; only windowBackground changes for dark mode.
        All color/typography/shape theming is done inside Compose via TodoTheme.
    -->
    <style name="Theme.Todo" parent="Theme.AppCompat.DayNight.NoActionBar">
        <item name="android:windowBackground">@android:color/black</item>
        <item name="android:windowAnimationStyle">@android:style/Animation.Activity</item>
    </style>
</resources>
