<?xml version="1.0" encoding="utf-8"?>
<resources>
    <!--
        Window-level theme for the Compose-only app.
        Theme.AppCompat.DayNight.NoActionBar is the standard parent for any Activity
        that uses Compose (no legacy View toolbar). AppCompat provides the XML style
        framework; all real theming (colors, typography, shapes) is done inside
        Compose via TodoTheme / MaterialTheme.
        android:windowBackground prevents a white flash before Compose draws its first frame.
    -->
    <style name="Theme.Todo" parent="Theme.AppCompat.DayNight.NoActionBar">
        <item name="android:windowBackground">@android:color/white</item>
        <item name="android:windowAnimationStyle">@android:style/Animation.Activity</item>
    </style>
</resources>
